configuration{
    modi: "drun,run,window,combi";
    icon-theme: "Papirus";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-combi: "   ";
    display-run: "   ";
    display-drun: " # ";
    display-window: "   ";
    sidebar-mode: false;
    me-accept-entry: "!MousePrimary"; 
    kb-cancel: "MousePrimary"; 
}

@theme "catppuccin-mocha"
