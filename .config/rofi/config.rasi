configuration{
    modi: "drun,run,window,combi";
    icon-theme: "Breeze";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-combi: " 🖥️ ";
    display-run: " 🧙‍♂️ ";
    display-drun: " 🏃 ";
    display-window: " 🪟 ";
    sidebar-mode: true;
}

@theme "catppuccin-mocha"
